# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
# IMPORTANT: Use "preview" for Responses API (required for reasoning models like  o1, o3)
# Use standard versions like "2024-10-21" for regular chat models
# AZURE_OPENAI_DEPLOYMENT will be used fo root cause analysis mode.
# AZURE_OPENAI_CLASSIFIER_DEPLOYMENT will be used for classifier model.
AZURE_OPENAI_API_VERSION=preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_CLASSIFIER_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_EMBEDDING_MODEL_NAME=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_MODEL_VERSION=2023-05-15
AZURE_AI_SEARCH_SERVICE_NAME=search-service-name
AZURE_AI_SEARCH_INDEX_NAME=index-name
AZURE_SEARCH_API_KEY=azure-search-api-key
AZURE_AI_SEARCH_API_VERSION=2025-09-01

# Tools API Configuration
KUBE_TOOLS_BASE_URL=http://your-kube-tools-api/api
NON_KUBE_TOOLS_BASE_URL=http://your-non-kube-tools-api/api
TOOLS_API_KEY=your-api-key-here
WEBHOOK_API_KEY=


# Classifier deployment for router, k8s-monitoring, and rag agents
AZURE_OPENAI_CLASSIFIER_DEPLOYMENT=gpt-4.1-mini

# Agent Behavior Configuration
AGENT_TEMPERATURE=0.7
AGENT_TOP_P=0.95
# AGENT_MAX_TOKENS=
# Reasoning effort for reasoning models (low/medium/high)
AGENT_REASONING_EFFORT=medium

# Langfuse Observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# App Port
APP_PORT=8001

# OpenTelemetry Configuration
ENABLE_OTEL=true
ENVIRONMENT=production
OTEL_ENABLE_SENSITIVE_DATA=true

# Microsoft Teams notifications (Adaptive Cards)
# Incoming webhook URL from a Power Automate "Workflows" flow
# ("Post to a channel when a webhook request is received") or a classic
# Office 365 connector. Leave empty to disable Teams delivery.
TEAMS_WEBHOOK_URL=
TEAMS_NOTIFICATIONS_ENABLED=true
